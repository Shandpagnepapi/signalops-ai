# Legacy Supabase cloud visual audit screenshots. Normal visual reviews now use
# GitHub Actions artifacts and do not require these screenshot env vars.
# Use only for public-page screenshots if the legacy workflow is needed.
# For uploads, prefer SUPABASE_SECRET_KEY for new Supabase API keys.
# Use SUPABASE_SERVICE_ROLE_KEY only for legacy service_role keys.
# Never use anon or publishable keys for visual audit uploads.
# GitHub Actions secrets are separate from Vercel environment variables.
VISUAL_AUDIT_ENABLED=
VISUAL_AUDIT_PUBLIC_KEY=
VISUAL_AUDIT_BUCKET=visual-audits
VISUAL_AUDIT_MAX_AGE_DAYS=30
VISUAL_AUDIT_MAX_RUNS=12
VISUAL_AUDIT_MAX_STORAGE_MB=300

# Future data layer
DATABASE_URL=
SIGNALOPS_INTERNAL_TOKEN=
